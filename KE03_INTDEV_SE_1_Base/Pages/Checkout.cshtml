@page
@model KE03_INTDEV_SE_1_Base.Pages.SearchModel


<script src="@Url.Content("~/js/CheckoutScript.js")"></script>
<link rel="stylesheet" href="~/css/CheckoutStyle.css" asp-append-version="true">

<body>
    @* <!-- HEADER -->
    <header class="homebar">

        <!-- Logo -->
        <div class="logo">
            <button class="home-button" onclick="window.location.href='/'">
                <img src="~/images/Logo.png" alt="Logo">
                <p>Matrix Inc.</p>
            </button>
        </div>  

        <!-- Search bar --> 
        <div class="search">
            <input type="text" placeholder="Zoek producten...">
        </div>

        <!-- Icons -->
        <div class="icons">

            <!-- Account -->
            <img src="~/images/Icon.png" alt="Icon">

            <!-- Wishlist -->
            <img src="~/images/Wishlist.png" alt="Wishlist">

            <!-- Cart -->
            <span class="icon" id="cart-icon">
                <img src="~/images/Cart.png" alt="Cart">
                <span>@Model.CartCount</span>
            </span>

        </div>

    </header> *@

    <!-- CART SUMMARY -->
    <main class="checkout-container">

        <div class="cart-summary-box">

            <h1>Order Summary</h1>

            <!-- Items -->
            <div class="summary-row">
                <p>Items</p>
                <span>@Model.CartCount</span>
            </div>

            <!-- Subtotaal -->
            <div class="summary-row">
                <p>Total</p>
                <span>€@Model.CartTotal.ToString("0.00")</span>
            </div>

            <!-- Shipping -->
            <div class="summary-row">
                <p>Shipping</p>
                <span>€@Model.ShippingCost.ToString("0.00")</span>
            </div>

            <!-- VAT -->
            <div class="summary-row">
                <p>VAT 21% Included</p>
                <span>€@Model.VAT.ToString("0.00")</span>
            </div>

            <hr>

            <!-- Eindtotaal -->
            <div class="summary-total">
                <h2>Final Total</h2>
                <h2>€@Model.FinalTotal.ToString("0.00")</h2>
            </div>

            <form method="post" asp-page-handler="Checkout">
                <button type="submit" class="checkout-button">
                    Afrekenen
                </button>
            </form>

            <button class="cancel-button" onclick="window.location.href='/'">
                Cancel Order
            </button>

        </div>
        <div class="cart-sidebar open"  id="cart-sidebar">

            <button class="close-cart" id="close-cart">✖</button>

            <div class="cart-title">
                <img src="~/images/Cart.png" alt="Cart">
            </div>

            @if (!Model.CartItems.Any())
            {
                <p>Cart is empty</p>
            }
            else
            {
                <ul>
                    @foreach (var item in Model.CartItems)
                    {
                        <li>
                            <div>
                                <strong>@item.Name</strong><br />
                                €@item.Price x @item.Quantity
                            </div>

                            <div>
                                <form method="post" asp-page-handler="RemoveFromCart">
                                    <input type="hidden" name="productId" value="@item.ProductId" />
                                    <button type="submit">Remove</button>
                                </form>
                            </div>
                        </li>
                    }
                </ul>

                <h3>
                    Totaal: €@Model.CartTotal.ToString("0.00")
                </h3>
            }

        </div>
    </main>
</body>