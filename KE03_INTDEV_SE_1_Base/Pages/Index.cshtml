@page
@model IndexModel
@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="nl">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Bestel Platform</title>

    <link rel="stylesheet" href="~/css/style.css">
</head>


<body>
    <!-- HOME BAR -->
    <header class="homebar">

        <!-- Logo -->
        <div class="logo">
            <img src="~/images/Logo.png" alt="Logo">
            <p>Matrix Inc.</p>
        </div>

        <!-- Search bar -->
        <div class="search">
            <input type="text" placeholder="Zoek producten...">
        </div>

        <!-- Icons -->
        <div class="icons">

            <!-- Account -->
            <img src="~/images/Icon.png" alt="Icon">

            <!-- Wishlist -->
            <img src="~/images/Wishlist.png" alt="Wishlist">

            <!-- Cart -->
            <span class="icon" id="cart-icon">
                <img src="~/images/Cart.png" alt="Cart">
                <span>@Model.CartCount</span>
            </span>

        </div>

    </header>

    <main class="shop-layout">
        <aside class="category-sidebar">
            <div class="menu-item">
                Badkamer & sanitair

                <div class="submenu">
                    <button>Douches</button>

                    <button>Toiletten</button>

                    <button>Kranen</button>
                </div>
            </div>

            <div class="menu-item">
                Keuken

                <div class="submenu">
                    <button>Keukens</button>

                    <button>Apparatuur</button>

                    <button>Accessoires</button>
                </div>
            </div>

            <div class="menu-item">
                Woonkamer

                <div class="submenu">
                    <button>Keukens</button>

                    <button>Apparatuur</button>

                    <button>Accessoires</button>
                </div>
            </div>

            <div class="menu-item">
                Gast-Kamer

                <div class="submenu">
                    <button>Keukens</button>

                    <button>Apparatuur</button>

                    <button>Accessoires</button>
                </div>
            </div>

            <div class="menu-item">
                Tuin

                <div class="submenu">
                    <button>Keukens</button>

                    <button>Apparatuur</button>

                    <button>Accessoires</button>
                </div>
            </div>
        </aside>

        <section class="product-section">

            @foreach (var product in Model.Products)
            {
                <div class="product">
                    <a asp-page="/Products/Details"
                        asp-route-id="@product.Id">
                        <img src="~/images/product_@(product.Id).png" alt="@product.Name" />

                        <a asp-page="/Product" asp-route-id="@product.Id">
                            <h2>@product.Name</h2>
                        </a>
                    </a>

                    <p>@product.Description</p>

                    <p>€@product.Price</p>

                    <form method="post" asp-page-handler="AddToCart">
                        <input type="hidden" name="productId" value="@product.Id" />
                        <input type="hidden" name="name" value="@product.Name" />
                        <input type="hidden" name="price" value="@product.Price" />

                        <button type="submit">
                            Bestellen
                        </button>
                    </form>
                </div>
            }

        </section>
    </main>

    <div class="cart-sidebar" id="cart-sidebar">

        <button class="close-cart" id="close-cart">✖</button>

        <div class="cart-title">
            <img src="~/images/Cart.png" alt="Cart">
        </div>

        @if (!Model.CartItems.Any())
        {
            <p>Cart is empty</p>
        }
        else
        {
            <ul>
                @foreach (var item in Model.CartItems)
                {
                    <li>
                        <div>
                            <strong>@item.Name</strong><br />
                            €@item.Price x @item.Quantity
                        </div>

                        <div>
                            <form method="post" asp-page-handler="RemoveFromCart">
                                <input type="hidden" name="productId" value="@item.ProductId" />
                                <button type="submit">Remove</button>
                            </form>
                        </div>
                    </li>
                }
            </ul>

            <h3>
                Totaal: €@Model.CartTotal.ToString("0.00")
            </h3>
        }

        <div class="cart-buttons">

            <button class="checkout-button"onclick="window.location.href='/Checkout'">
                Afrekenen
            </button>

        </div>

    </div>

</body>

<script src="~/js/script.js"></script>

</html>











